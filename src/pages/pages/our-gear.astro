---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Our Gear — Open Atlas";
const description = "Field-tested gear we actually use, reviewed honestly. Affiliate disclosure included.";
const heroImage = "assets/images/hero/our-gear.jpg";
const ogTitle = "Our Gear — Open Atlas";
const ogDescription = "Field-tested gear we actually use, reviewed honestly.";
const ogImage = "assets/images/hero/our-gear.jpg";
const tags = ["gear", "site"];
---

<BaseLayout 
  title={title}
  description={description}
  heroImage={heroImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  bodyClass="gear"
>
      <section class="hero hero--short">
        <div class="hero__media">
          <img src="../../assets/images/hero/our-gear.jpg" alt="Field-tested gear on the trail." />
        </div>
        <div class="container hero__content">
          <nav aria-label="Breadcrumb">
            <ol class="breadcrumbs">
              <li><a href="../../">Home</a></li>
              <li>Our Gear</li>
            </ol>
          </nav>
          <span class="hero__eyebrow">Gear, field tested</span>
          <h1 class="hero__title">The real gear that earned its keep in the rig.</h1>
          <p class="hero__sub">
            From quick day hikes to <a
              href="https://openatlas.wiki/pages/pages/journal/tamolitch-falls-blue-pool/"
              >Tamolitch Falls</a
            > to multi-day overland epics, we push our gear to the limit and only the toughest survive.
          </p>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div style="max-width: 48rem; margin: 0 auto var(--sp-5) auto; text-align: center;">
            <p class="lede" style="font-size: 1.25rem; font-style: italic; line-height: 1.5;">
              Picture this: you're scrambling up volcanic ridges at dawn, fording wild rivers in the
              FJ Cruiser, or base camping deep in national forests under star-packed skies. We
              field-test everything on real trips, sharing honest lessons, epic fails, and raves for
              the kit that powers our adventures.
            </p>
          </div>

          <div style="max-width: 48rem; margin: 0 auto;">
            <p
              style="font-size: 10pt; margin: 0 auto var(--sp-4) auto; max-width: 36rem; text-align: center; color: var(--text-secondary);"
            >
              Affiliate disclosure: As Amazon Associates participants, we may earn commissions from
              qualifying purchases through our links at no extra cost to you. This supports our
              trips and content. We only recommend gear we've tested and love.
            </p>
          </div>

          <div
            class="row reveal"
            style="margin-bottom: var(--sp-4); justify-content: space-between; align-items: baseline;"
          >
            <div>
              <span class="eyebrow">Gear</span>
              <h2 style="margin-bottom: 0;">All gear</h2>
            </div>
            <div class="row" data-gear-tags></div>
          </div>

          <div class="card-grid" data-gear-items></div>
        </div>
      </section>
    </BaseLayout>
