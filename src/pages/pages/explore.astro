<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Explore — Open Atlas</title>
  <meta name="description" content="Latest destinations, gear reviews, and field notes from the Open Atlas journal." />
  <meta name="theme-color" content="#0b0d0e" />
  <link rel="icon" href="../../assets/images/meta/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../../assets/css/tokens.css" />
  <link rel="stylesheet" href="../../assets/css/base.css" />
  <link rel="stylesheet" href="../../assets/css/components.css" />
  <link rel="stylesheet" href="../../assets/css/pages.css" />
</head>
<body data-page="explore">
  <div data-site-header></div>

  <main id="main">
    <section class="hero hero--short">
      <div class="hero__media">
        <img src="../../assets/images/destinations/forest-trail.jpg" alt="Forest trail disappearing into evergreen canopy." />
      </div>
      <div class="container hero__content">
        <nav aria-label="Breadcrumb">
          <ol class="breadcrumbs">
            <li><a href="../../">Home</a></li>
            <li>Explore</li>
          </ol>
        </nav>
        <span class="hero__eyebrow">Our latest destinations</span>
        <h1 class="hero__title">Field notes from the trail.</h1>
        <p class="hero__sub">
          Every entry starts as a trip we actually took — scouted, walked,
          driven, and documented. No stock photos, no hype.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="row reveal" style="margin-bottom: var(--sp-4); justify-content: space-between; align-items: baseline;">
          <div>
            <span class="eyebrow">Journal</span>
            <h2 style="margin-bottom: 0;">All entries</h2>
          </div>
          <div class="row" data-tags></div>
        </div>

        <div class="card-grid" data-all-posts></div>
      </div>
    </section>
  </main>

  <div data-site-footer></div>
  <script type="module" src="../../assets/js/main.js"></script>
</body>
</html>
