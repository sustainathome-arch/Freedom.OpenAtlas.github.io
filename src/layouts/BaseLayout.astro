---
export interface Props {
	title: string;
	description: string;
	heroImage?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogImage?: string;
	tags?: string[];
	bodyClass?: string;
}

const {
	title,
	description,
	heroImage = "assets/images/hero/site-hero.jpg",
	ogTitle = title,
	ogDescription = description,
	ogImage = heroImage,
	tags = [],
	bodyClass = ""
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VTDBJ09QFT"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: unknown[]){window.dataLayer.push(args);}
      gtag('js', new Date());

      gtag('config', 'G-VTDBJ09QFT');
    </script>
    
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0d0e" />
    <meta name="google-adsense-account" content="ca-pub-8220740031086004" />

    <link rel="icon" href="/assets/images/meta/favicon.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/assets/css/tokens.css" />
    <link rel="stylesheet" href="/assets/css/base.css" />
    <link rel="stylesheet" href="/assets/css/components.css" />
    <link rel="stylesheet" href="/assets/css/pages.css" />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`https://openatlas.wiki/${ogImage}`} />
  </head>
  <body data-page={bodyClass}>
    <div data-site-header></div>

    <main id="main">
      <slot />
    </main>

    <div data-site-footer></div>
    <script type="module" src="/assets/js/main.js"></script>
  </body>
</html>
