---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Contact — Open Atlas</title>
    <meta
      name="description"
      content="Say hello. Partner with us. Share a destination we should scout."
    />
    <meta name="theme-color" content="#0b0d0e" />
    <link rel="icon" href="/assets/images/meta/favicon.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../../assets/css/tokens.css" />
    <link rel="stylesheet" href="../../assets/css/base.css" />
    <link rel="stylesheet" href="../../assets/css/components.css" />
    <link rel="stylesheet" href="../../assets/css/pages.css" />
  </head>
  <body data-page="contact">
    <div data-site-header></div>

    <main id="main">
      <section class="hero hero--short">
        <div class="hero__media">
          <img
            src="../../assets/images/destinations/pnw-vista.jpg"
            alt="Ridgeline at golden hour."
          />
        </div>
        <div class="container hero__content">
          <nav aria-label="Breadcrumb">
            <ol class="breadcrumbs">
              <li><a href="../../">Home</a></li>
              <li>Contact</li>
            </ol>
          </nav>
          <span class="hero__eyebrow">Get in touch</span>
          <h1 class="hero__title">Say hello from the trail.</h1>
          <p class="hero__sub">
            Have a destination suggestion, a partnership idea, or a question about a trip? We'd love
            to hear from you.
          </p>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="contact-grid">
            <div class="reveal">
              <span class="eyebrow">How to reach us</span>
              <h2>Three ways to connect.</h2>
              <p class="lede">
                We read every message. Responses may be slower when we're out documenting a trip —
                but we always come back around.
              </p>

              <div class="contact-cards" style="margin-top: var(--sp-4);">
                <article class="contact-card">
                  <span class="contact-card__icon">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M3 7l9 6 9-6"
                      ></path></svg
                    >
                  </span>
                  <div>
                    <h3>Email</h3>
                    <p>
                      The best way for partnership and press inquiries. We respond within a week.
                    </p>
                    <p><a href="mailto:hello@openatlas.wiki">hello@openatlas.wiki</a></p>
                  </div>
                </article>
                <article class="contact-card">
                  <span class="contact-card__icon">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1118 0z"></path><circle
                        cx="12"
                        cy="10"
                        r="3"></circle></svg
                    >
                  </span>
                  <div>
                    <h3>Where we roam</h3>
                    <p>
                      Home base is the Pacific Northwest, with regular runs into Northern California
                      and the Intermountain West.
                    </p>
                  </div>
                </article>
                <article class="contact-card">
                  <span class="contact-card__icon">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"><path d="M4 4h16v12H6l-2 4z"></path></svg
                    >
                  </span>
                  <div>
                    <h3>Destination tips</h3>
                    <p>
                      Know a trail, lava tube, waterfall, or back road we need to scout? Tell us —
                      the message box on the right is the fastest way.
                    </p>
                  </div>
                </article>
              </div>
            </div>

            <div class="fund-panel reveal">
              <h2 style="margin-top:0;">Drop us a line.</h2>
              <form class="stack" data-contact-form novalidate>
                <div class="form-grid">
                  <div class="field">
                    <label for="name">Your name</label>
                    <input
                      class="input"
                      type="text"
                      id="name"
                      name="name"
                      autocomplete="name"
                      required
                    />
                  </div>
                  <div class="field">
                    <label for="email">Email</label>
                    <input
                      class="input"
                      type="email"
                      id="email"
                      name="email"
                      autocomplete="email"
                      required
                    />
                  </div>
                </div>
                <div class="field">
                  <label for="topic">Topic</label>
                  <select class="select" id="topic" name="topic">
                    <option>Just saying hello</option>
                    <option>Destination suggestion</option>
                    <option>Gear question</option>
                    <option>Partnership / press</option>
                    <option>Other</option>
                  </select>
                </div>
                <div class="field">
                  <label for="message">Message</label>
                  <textarea class="textarea" id="message" name="message" required></textarea>
                </div>
                <div class="row" style="justify-content: space-between;">
                  <p
                    class="text-muted"
                    style="font-size: var(--fs-xs); margin: 0; max-width: 22rem;"
                  >
                    This form is a placeholder. Wire it to a service like Formspree, Basin, or your
                    own endpoint when ready.
                  </p>
                  <button class="btn" type="submit">
                    Send message
                    <svg
                      class="btn__arrow"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                    >
                      <path d="M5 12h14"></path><path d="M13 5l7 7-7 7"></path>
                    </svg>
                  </button>
                </div>
                <p
                  class="text-secondary"
                  data-contact-status
                  aria-live="polite"
                  style="min-height: 1.4rem;"
                >
                </p>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <div data-site-footer></div>
    <script type="module" src="../../assets/js/main.js"></script>
  </body>
</html>
