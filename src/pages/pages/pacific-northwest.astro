<body data-page="pacific-northwest">
  <div data-site-header></div>

  <main id="main">
    <section class="hero hero--short">
      <div class="hero__media">
        <img src="../../assets/images/destinations/pnw-vista.jpg" alt="A Pacific Northwest vista with fog clinging to distant ridgelines." />
      </div>
      <div class="container hero__content">
        <nav aria-label="Breadcrumb">
          <ol class="breadcrumbs">
            <li><a href="../../">Home</a></li>
            <li>Pacific Northwest</li>
          </ol>
        </nav>
        <span class="hero__eyebrow">Destination directory</span>
        <h1 class="hero__title">The great PNW.</h1>
        <p class="hero__sub">
          Check out our travels. This directory is organized by states in the
          great Pacific Northwest. New destinations are added as we scout them.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container" data-destinations></div>
    </section>
  </main>

  <div data-site-footer></div>
  <script type="module" src="../../assets/js/main.js"></script>
