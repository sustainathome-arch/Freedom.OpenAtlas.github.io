---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Fuel the Adventure — Open Atlas";
const description = "Help power the FJ Fund and the Travel Fund. Every contribution goes to more miles, better gear, and more stories from the trail.";
const heroImage = "assets/images/hero/fuel-the-adventure.jpg";
const ogTitle = "Fuel the Adventure — Open Atlas";
const ogDescription = "Support the FJ Fund and the Travel Fund. Help us keep rolling.";
const ogImage = "https://openatlas.wiki/assets/images/hero/fuel-the-adventure.jpg";
const tags = ["fuel", "support"];
---

<BaseLayout 
  title={title}
  description={description}
  heroImage={heroImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  bodyClass="fuel"
>
      <!-- Hero -->
      <section class="hero">
        <div class="hero__media">
          <img
            src="../../assets/images/hero/fuel-the-adventure.jpg"
            alt="A forest trail lit by golden-hour light."
          />
        </div>
        <div class="container hero__content">
          <nav aria-label="Breadcrumb">
            <ol class="breadcrumbs">
              <li><a href="../../">Home</a></li>
              <li>Fuel the Adventure</li>
            </ol>
          </nav>
          <span class="hero__eyebrow">Support the work</span>
          <h1 class="hero__title">Fuel the adventure.</h1>
          <p class="hero__sub">
            Every contribution helps us go farther, build better, and create more content from the
            field. Choose the trail you'd like to support.
          </p>
          <div class="hero__actions">
            <a class="btn btn--lg" href="#funds">
              Choose your trail
              <svg
                class="btn__arrow"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              >
                <path d="M12 5v14"></path>
                <path d="M5 13l7 7 7-7"></path>
              </svg>
            </a>
            <a class="btn btn--ghost btn--lg" href="../fj13/">About the rig</a>
          </div>
        </div>
      </section>

      <!-- Intro: "The road is calling" -->
      <section class="section">
        <div class="container">
          <div class="fta-intro">
            <div class="fta-intro__media reveal">
              <img
                src="../../assets/images/hero/fuel-the-adventure.jpg"
                alt="A canyon overlook at sunset."
              />
            </div>
            <div class="reveal">
              <span class="eyebrow">The road is calling</span>
              <h2 style="font-size: var(--fs-4xl);">From volcanic ridgelines to rushing rivers.</h2>
              <p class="lede">
                From volcanic ridgelines and rushing rivers to deep forests, high desert trails, and
                the wild edges of national parks, this site is built to share the journey.
              </p>
              <p>
                We explore nature, document the places we reach, and bring back stories, photos, and
                practical travel notes for people who love the outdoors, overlanding, and real
                adventure. <strong>Fuel the Adventure</strong> is how you can help keep that mission moving.
              </p>
              <p class="text-secondary">
                You can choose to support the <strong>FJ Fund</strong> or the
                <strong>Travel Fund</strong>, depending on what you most want to help power.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Choose your trail -->
      <section class="section section--tight" id="funds">
        <div class="container">
          <div class="section-heading center reveal" style="margin-inline:auto;">
            <span class="eyebrow" style="justify-content:center;">Choose your trail</span>
            <h2 class="section-heading__title">Support the trip you care about.</h2>
            <p class="section-heading__lede" style="margin-inline:auto;">
              Two focused funds. Pick the one that matches the work you want to see more of — or
              back both.
            </p>
          </div>

          <div class="fta-funds">
            <!-- FJ Fund -->
            <article class="fund-panel reveal">
              <header class="fund-panel__header">
                <div>
                  <span class="fund-panel__kicker">
                    <svg
                      viewBox="0 0 24 24"
                      width="14"
                      height="14"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      ><path d="M4 17h16l-2-6H6l-2 6z"></path><circle cx="8" cy="18.5" r="1.5"
                      ></circle><circle cx="16" cy="18.5" r="1.5"></circle><path
                        d="M6 11V8a2 2 0 012-2h6l4 5"></path></svg
                    >
                    The FJ Fund
                  </span>
                  <h3 class="fund-panel__title">Keep the rig ready for the long haul.</h3>
                </div>
                <span class="fund-panel__badge">Trail rig</span>
              </header>

              <div class="fund-panel__photos" data-photo-fj></div>

              <div class="fund-panel__body">
                <p>
                  The FJ Cruiser is more than just a vehicle — it's the machine that carries us into
                  remote places, over rough roads, and toward the stories we want to share. Your
                  support helps us upgrade, maintain, and prepare the rig for tougher terrain and
                  better travel coverage.
                </p>
                <h4 style="margin-top: var(--sp-4);">What the FJ Fund supports</h4>
                <ul class="fund-panel__list">
                  <li>Suspension upgrades for rough roads and backcountry trails.</li>
                  <li>All-terrain tires for dirt, gravel, snow, and mixed terrain.</li>
                  <li>Recovery gear for getting unstuck when the trail gets real.</li>
                  <li>Storage and cargo solutions for camping and camera kits.</li>
                  <li>Lighting upgrades for early starts, late arrivals, and night setup.</li>
                  <li>Electrical and power upgrades for charging gear on the road.</li>
                  <li>General maintenance to keep the FJ dependable, mile after mile.</li>
                </ul>
                <p class="text-secondary">
                  A stronger, better-prepped FJ means we can reach deeper into wild places, stay
                  safer on remote routes, and create more useful content for other travelers and
                  overlanders.
                </p>
              </div>

              <div class="fund-panel__footer">
              <a class="btn" href="https://buymeacoffee.com/openatlas">Support the FJ</a>
                <a class="card__cta" href="../fj13/">See the rig →</a>
              </div>
            </article>

            <!-- Travel Fund -->
            <article class="fund-panel fund-panel--moss reveal">
              <header class="fund-panel__header">
                <div>
                  <span class="fund-panel__kicker">
                    <svg
                      viewBox="0 0 24 24"
                      width="14"
                      height="14"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><path d="M3 20l5-12 4 7 3-5 6 10H3z"></path><circle cx="17" cy="6" r="2"
                      ></circle></svg
                    >
                    The Travel Fund
                  </span>
                  <h3 class="fund-panel__title">Keep the adventure alive.</h3>
                </div>
                <span class="fund-panel__badge">Every trip</span>
              </header>

              <div class="fund-panel__photos" data-photo-travel></div>

              <div class="fund-panel__body">
                <p>
                  Every trip takes fuel, permits, campsite fees, food, and the small but important
                  costs that turn a route on the map into a real experience. This fund helps us keep
                  exploring, keep documenting, and keep sharing the journey with people who love the
                  outdoors.
                </p>
                <h4 style="margin-top: var(--sp-4);">What the Travel Fund supports</h4>
                <ul class="fund-panel__list">
                  <li>Fuel for road trips and trail access.</li>
                  <li>Park, forest, and recreation fees.</li>
                  <li>Campsites, dispersed camping costs, and overnight stays.</li>
                  <li>Route planning, maps, and travel preparation.</li>
                  <li>Trip supplies and field essentials.</li>
                  <li>Content creation costs like storage, batteries, and publishing tools.</li>
                </ul>
                <p class="text-secondary">
                  Your support helps bring back stories from the road, the river, the forest, and
                  the mountains — while making it possible to keep producing outdoor content that is
                  useful, authentic, and grounded in real travel.
                </p>
              </div>

              <div class="fund-panel__footer">
                <a class="btn" href="https://buymeacoffee.com/openatlas">Support the Travel Fund</a>
                <a class="card__cta" href="../pacific-northwest/">See where we're headed →</a>
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- What your support helps us do -->
      <section class="section section--tight">
        <div class="container">
          <div class="section-heading reveal">
            <span class="eyebrow">What your support helps us do</span>
            <h2 class="section-heading__title">More than just miles.</h2>
          </div>

          <div data-photo-support></div>

          <div class="reveal" style="max-width: 60rem; margin-top: var(--sp-5);">
            <p>
              When you give, you're not just sending money — you're helping send the rig farther,
              the story deeper, and the next adventure into the wild. You help us reach places that
              inspire people to explore, travel responsibly, and connect with nature.
            </p>
            <p class="text-secondary">
              You also help support young travelers and creators who are learning, building, and
              documenting the outdoors one trip at a time. Whether you choose to back the FJ or fuel
              the road ahead, your gift helps keep this project moving forward.
            </p>
          </div>
        </div>
      </section>

      <!-- Why we do this -->
      <section class="section section--tight">
        <div class="container">
          <div class="fta-why reveal">
            <div>
              <span class="eyebrow">Why we do this</span>
              <h2 style="font-size: var(--fs-3xl); margin-top: var(--sp-1);">
                Explored, respected, and shared.
              </h2>
              <p>
                We believe the outdoors should be explored, respected, and shared. We believe in
                building something real — a site filled with travel stories, practical resources,
                and honest field-tested content for people who love overlanding, off-road travel,
                and public lands.
              </p>
              <p class="text-secondary">
                We're here to chase good roads, great views, and the kind of stories that only come
                from actually being out there.
              </p>
            </div>
            <div class="callout">
              <p class="quote-block" style="margin:0; font-size: var(--fs-xl);">
                Help us keep rolling. Help us keep exploring. Help us fuel the adventure.
              </p>
              <br />
              
              <div>
                <a class="btn" href="https://buymeacoffee.com/openatlas">Support the Travel Fund</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Thank you -->
      <section class="section section--tight">
        <div class="container">
          <div class="fta-thanks reveal">
            <div class="fta-thanks__media">
              <img
                src="../../assets/images/travel/thank-you.jpg"
                alt="Golden-hour coastline seen from the road."
              />
            </div>
            <div class="fta-thanks__content">
              <span class="eyebrow">Thank you</span>
              <h2 style="font-size: var(--fs-4xl); margin-top: var(--sp-2);">
                Every supporter becomes part of the journey.
              </h2>
              <p class="lede" style="color: rgba(241, 243, 244, 0.9);">
                Your contribution helps us keep the FJ moving, the content coming, and the adventure
                alive. We're grateful for every mile you help us cover.
              </p>
              <div class="hero__actions">
                <a class="btn" href="https://buymeacoffee.com/openatlas">Join the Mission</a>

                <a class="btn btn--ghost" href="../explore/">Read the latest journal</a>

                <a class="btn btn--ghost" href="../contact/">Say hello</a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </BaseLayout>
